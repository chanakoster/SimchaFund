@using SimchaFund.Data
@model ContributorsViewModel

<div>
    <h1>Contributors</h1>
</div>
<div class="row">
    <div class="col-md-2">
        <button class="btn btn-danger" id="new-contributor">New Contributor</button>
    </div>
    <div class="col-md-6">
        <input type="text" class="form-control-sm" placeholder="Search" id="search" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-outline-secondary" id="clear">Clear</button>
    </div>
    <div class="col-md-2">
        <h3>@Model.Total.ToString("C")</h3>
    </div>
</div>
<div class="table-responsive">
    <table class="table table-striped table-bordered">
        <tr>
            <th>Deposit</th>
            <th>Name</th>
            <th>Cell</th>
            <th>Balance</th>
            <th>Always Include</th>
            <th>Actions</th>
        </tr>
        @foreach (var contributor in Model.Contributors)
        {
            <tr>
            <td>
                <button class="btn btn-success deposit-button" data-contribid="@contributor.Id">Deposit</button>
            </td>
            <td>@contributor.FirstName @contributor.LastName</td>
            <td>@contributor.CellNumber</td>
            <td>@contributor.Balance.ToString("C")</td>
            <td style="text-align: center;">
                    @if (contributor.AlwaysInclude)
                    {
                        <i style="font-size:30px" class="bi bi-check"></i>
                    }
            </td>
            <td>
                <a href="/contributors/history?contributorId=@contributor.Id" class="btn btn-primary">Show History</a>
                <button data-first-name="@contributor.FirstName" data-last-name="@contributor.LastName"
                        data-cell="@contributor.CellNumber" data-id="@contributor.Id" data-always-include="@contributor.AlwaysInclude" data-date="@contributor.Date.ToString("yyyy-MM-dd")"
                        class="btn btn-danger edit-contrib">
                    Edit
                </button>
            </td>
        </tr>
        }
    </table>
</div>

<div class="modal fade new-contrib" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Contributor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/contributors/new">
                <div class="modal-body">
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label class="form-label">First Name</label>
                            <input class="form-control" id="contributor_first_name" name="firstName" placeholder="First Name" type="text">
                        </div>
                        <div class="form-group col-md-6">
                            <label class="form-label">Last Name</label>
                            <input class="form-control" id="contributor_last_name" name="lastName" placeholder="Last Name" type="text">
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="form-group col-md-6">
                            <label class="form-label">Cell Number</label>
                            <input class="form-control" id="contributor_cell_number" name="cellNumber" placeholder="Cell Number" type="text">
                        </div>
                        <div class="form-group col-md-6" id="initialDepositDiv">
                            <label class="form-label">Initial Deposit</label>
                            <input type="text" class="form-control" name="amount" placeholder="Initial Deposit" value="100">
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="form-group col-md-6">
                            <label class="form-label">Created Date</label>
                            <input class="form-control" id="contributor_created_at" name="date" placeholder="Date" type="date">
                        </div>
                        <div>
                            <div class="form-check mt-3 ml-3">
                                <input type="checkbox" class="form-check-input" id="contributor_always_include" name="alwaysInclude" value="true">
                                <label class="form-check-label" for="contributor_always_include">Always Include</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade contrib-edit" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Contributor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/contributors/edit">
                <input type="hidden" id="edit_contributor-id" name="id" value="" />
                <div class="modal-body">
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label class="form-label">First Name</label>
                            <input class="form-control" id="edit_contributor_first_name" name="firstName" placeholder="First Name" type="text">
                        </div>
                        <div class="form-group col-md-6">
                            <label class="form-label">Last Name</label>
                            <input class="form-control" id="edit_contributor_last_name" name="lastName" placeholder="Last Name" type="text">
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="form-group col-md-6">
                            <label class="form-label">Cell Number</label>
                            <input class="form-control" id="edit_contributor_cell_number" name="cellNumber" placeholder="Cell Number" type="text">
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="form-group col-md-6">
                            <label class="form-label">Created Date</label>
                            <input class="form-control" id="edit_contributor_created_at" name="date" type="date">
                        </div>
                        <div>
                            <div class="form-check mt-3 ml-3">
                                <input type="checkbox" class="form-check-input" id="edit_contributor_always_include" name="alwaysInclude">
                                <label class="form-check-label" for="edit_contributor_always_include">Always Include</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade deposit" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Deposit for <span id="deposit-name"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/contributors/deposit">
                <input type="hidden" name="contributorId" value="1" />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Amount</label>
                        <input class="form-control" name="amount" placeholder="Deposit Amount" type="text" value="50">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Date</label>
                        <input type="date" name="date" class="form-control" id="datepicker" value="2026-04-01">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <input class="btn btn-primary" name="commit" type="submit" value="Save">
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="/js/contributor-index.js"></script>
}

@using SimchaFund.Data
@model ContributionViewModel

<div class="header">
    <h1>
        Contributors for the
        @Model.Simcha.Name Simcha
    </h1>
</div>
<div class="table-responsive">
    <form method="POST" action="/simchas/updatecontributions">
        <input type="hidden" name="simchaId" value="@Model.Simcha.Id" />
        <table class="table table-bordered table-striped">
            <tr>
                <th>Contribute</th>
                <th>Name</th>
                <th>Balance</th>
                <th>Always Include</th>
                <th>Amount</th>
            </tr>
            @for (int i = 0; i < Model.Contributors.Count; i++)
            {
                <tr>
                    <td>
                        <input type="hidden" name="contributions[@i].ContributorId" value="@Model.Contributors[i].Id" />
                        <div class="d-flex justify-content-center">
                            <div class="form-check form-switch">
                                @if (Model.Contributors[i].Included)
                                {
                                    <input style="width: 4rem; height: 2rem;" name="contributions[@i].Included" class="form-check-input" type="checkbox" checked value="true">
                                }
                                else
                                {
                                    <input style="width: 4rem; height: 2rem;" name="contributions[@i].Included" class="form-check-input" type="checkbox" value="true">
                                }
                            </div>
                        </div>
                    </td>
                    <td>@Model.Contributors[i].FirstName @Model.Contributors[i].LastName</td>
                    <td>@Model.Contributors[i].Balance.ToString("C")</td>
                    <td style="text-align: center;">
                        @if (Model.Contributors[i].AlwaysInclude)
                        {
                            <i style="font-size:30px" class="bi bi-check"></i>
                        }
                    </td>
                    <td>
                        @{
                            decimal amount = Model.Contributors[i].Included ? Model.Contributors[i].AmountIncluded.Value : 5;
                        }
                        <input type="text" name="contributions[@i].Amount" class="form-control" value="@amount" />
                    </td>
                </tr>
            }

        </table>
        <div style="text-align:center;">
            <button class="btn-lg btn-danger">Update</button>
        </div>
    </form>
</div>
